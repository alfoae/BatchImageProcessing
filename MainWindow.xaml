<Window x:Class="ImageProcessing.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Petkanich_ImageProcessing"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" Width="1600"
        x:Name="MainPage"
        
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0" Background="DarkGray" >
            <Button Content="Start" Margin="5" Width="131" Click="StartButton_Click"/>
            <Button Content="Головна сторінка" Margin="5" Width="131" Click="GoToMain_Click"/>
            <Button Content="Налаштування" Margin="5" Width="131" Click="GoToSettings_Click"/>
            <Button Content="Історія" Margin="5" Width="131" Click="GoToHistory_Click"/>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>



    </Grid>

</Window>
