<Page x:Class="ImageProcessing.Settings"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ImageProcessing"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1600"
      Title="Settings"
      x:Name="SettingsPage">



    <Grid Background="#333333">

        <Grid.RowDefinitions>
            <RowDefinition Height="0"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
        </Grid.ColumnDefinitions>

        <Border
            Grid.Row="2" Background="#999999" 
            BorderThickness="2"
            CornerRadius="25, 25, 0, 0"
            Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>

                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#545454" HorizontalAlignment="Stretch" BorderThickness="0" CornerRadius="10, 10, 0, 0" Grid.Column="1" VerticalAlignment="Top" Height="50">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <!--верхня панель-->

                        <!--верхній ряд-->
                        <Border Grid.Row="0" Grid.Column="0" Background="#f9f9f9" Margin="5,9,5,1" CornerRadius="5, 0, 0, 5">
                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Вхід"/>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" Background="#f9f9f9" Margin="0,9,0,1" CornerRadius="0, 0, 0, 0">
                            <TextBox x:Name="M1FolderEnter" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Text="Вхід" Padding="-2" LostFocus="SelectFolder_Click"/>
                        </Border>

                        <Button Grid.Row="0" Grid.Column="2" Background="#f9f9f9" Margin="5,9,5,1" Padding="-3" Content="Browse..." x:Name="ButtonEnter" Click="SelectFolder_Click">

                        </Button>

                        <!--нижній ряд-->
                        <Border Grid.Row="1" Background="#f9f9f9" Margin="5,3,5,6" CornerRadius="5, 0, 0, 5">
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Вихід"/>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Background="#f9f9f9" Margin="0,3,0,6" CornerRadius="0, 0, 0, 0">
                            <TextBox x:Name="M1FolderOut" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Text="Вихід" Padding="-2" LostFocus="SelectFolder_Click"/>
                        </Border>

                        <Button Grid.Row="1" Grid.Column="2" Background="#f9f9f9" Margin="5,3,5,6" Padding="-2" Content="Browse..." x:Name="ButtonOut" Click="SelectFolder_Click">

                        </Button>

                        <!--нижня панель-->
                    </Grid>
                </Border>

                <!--фото-->
                <Grid Grid.Row="1">
                    <Border x:Name="SquareBorder" 
                            Grid.Row="1" Grid.Column="0" Margin="4,0,0,0" Background="#999999" 
                            CornerRadius="0" VerticalAlignment="Stretch" HorizontalAlignment="Left" 
                            Width="{Binding RelativeSource={RelativeSource Self}, Path=ActualHeight}"
                            ClipToBounds="True" SizeChanged="SquareBorder_SizeChanged">

                        <Canvas x:Name="PreviewCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Rectangle x:Name="PreviewRectangle" Stroke="White" StrokeThickness="2" Fill="#55FFFFFF" />
                        </Canvas>

                    </Border>
                </Grid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding ElementName=SquareBorder, Path=ActualWidth}" />
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Row="2" Grid.Column="0" Margin="3,0,-3,3" Background="#545454">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="GoBack" Grid.Column="0" Margin="0,0,0,0" Click="GoBack_Click">
                            <Polygon Points="4,0 0,4 4,8" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <Button x:Name="GoForward" Grid.Column="1" Margin="0,0,0,0" Click="GoForward_Click">
                            <Polygon Points="0,0 4,4 0,8" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Grid>

                <!--налаштування-->

                <Grid Grid.Row="1" Grid.RowSpan="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding ElementName=SquareBorder, Path=ActualWidth}" />
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="1" Background="Gray" Margin="8,0,3,3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                
                            </Grid.RowDefinitions>

                            <!--якість, формат-->

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="216"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>

                                <ToggleButton x:Name="ApplyToAll" Grid.Column="1" Content="Для цьго поля" Margin="3,3,1.5,3" Checked="ApplyToAll_Checked" Unchecked="ApplyToAll_Unchecked"/>

                                <Border Grid.Column="0" Background="#f9f9f9" Margin="4,3,1.5,3">
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Завантажити/Зберегти налаштування"/>
                                </Border>

                                <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Height="22">
                                    <ComboBox     x:Name="MyComboBoxN3" Grid.Column="2" Margin="3,0,3,0" IsEditable="True" IsReadOnly="False" StaysOpenOnEdit="True" SelectionChanged="MyComboBoxN3_SelectionChanged"/>
                                </StackPanel>

                                <Button x:Name="SaveProfile" Grid.Column="3" Margin="1.5,4,3,4" Content="Save" Click="SaveProfile_Click">
                                </Button>

                                <Button x:Name="DeleteProfile" Grid.Column="4" Margin="1.5,4,3,4" Content="Del" Click="DeleteProfile_Click">
                                </Button>
                            </Grid>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="55" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Row="1" Grid.Column="0" Background="#f9f9f9" Margin="5,4,1.5,5" >
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Якість"/>
                                </Border>


                                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                    <ComboBox x:Name="MyComboBox" SelectedIndex="0" Margin=" 3,0,-1,0" SelectionChanged="MyComboBox_SelectionChanged">
                                        <ComboBoxItem Content="144p"/>
                                        <ComboBoxItem Content="240p"/>
                                        <ComboBoxItem Content="360p"/>
                                        <ComboBoxItem Content="480p"/>
                                        <ComboBoxItem Content="720p"/>
                                        <ComboBoxItem Content="1080p"/>
                                        <ComboBoxItem Content="2к"/>
                                        <ComboBoxItem Content="4к"/>
                                    </ComboBox>
                                </StackPanel>

                                <Border Grid.Row="1" Grid.Column="2" Background="#f9f9f9" Margin="5,4,1.5,5" >
                                    <TextBlock Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Формат:"/>
                                </Border>

                                <StackPanel Grid.Column="3" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                    <ComboBox x:Name="MyComboBox1" SelectedIndex="0" Margin="1.5,0,3,0" SelectionChanged="MyComboBox1_SelectionChanged">
                                        <ComboBoxItem Content="PNG"/>
                                        <ComboBoxItem Content="JPEG"/>
                                        <ComboBoxItem Content="WebP"/>
                                        <ComboBoxItem Content="AVIF"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!--ширина висота-->

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="GlobalSizeSwitch" Grid.Column="0" Content="OFF" Margin="3,3,1.5,3" Click="GlobalSizeSwitch_Click"/>
                                <Border Grid.Column="1" Background="#f9f9f9" Margin="4,4.5,3,4.5" >
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Center" Text="Один розмір для всіх"/>
                                </Border>
                            </Grid>



                            <Grid Grid.Row="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="25" />
                                    <ColumnDefinition Width="25" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Row="1" Grid.Column="0" Background="#f9f9f9" Margin="4,3,1.5,3" >
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Висота"/>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Background="#f9f9f9" Margin="4,3,-4,3" >
                                    <TextBox x:Name="HeightBox" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="2" Text="" TextChanged="TextBoxes_TextChanged"/>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="2" Background="#f9f9f9" Margin="4,3,0,3" >
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Px."/>
                                </Border>

                                <Grid Grid.Column="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Button Grid.Row="0" Margin="0,2,3,0" Click="AdjustValue_Click" Tag="HeightBox_Up">
                                        <Polygon Points="0,4 4,0 8,4" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Grid.Row="1" Margin="0,0,3,2" Click="AdjustValue_Click" Tag="HeightBox_Down">
                                        <Polygon Points="0,0 4,4 8,0" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="25" />
                                    <ColumnDefinition Width="25" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Row="1" Grid.Column="0" Background="#f9f9f9" Margin="4,3,1.5,3" >
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Ширина"/>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="1" Background="#f9f9f9" Margin="4,3,-4,3" >
                                    <TextBox x:Name="WidthBox" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="2" Text="" TextChanged="TextBoxes_TextChanged"/>
                                </Border>

                                <Border Grid.Row="1" Grid.Column="2" Background="#f9f9f9" Margin="4,3,0,3" >
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Px."/>
                                </Border>

                                <Grid Grid.Column="3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Button Grid.Row="0" Margin="0,2,3,0" Click="AdjustValue_Click" Tag="WidthBox_Up">
                                        <Polygon Points="0,4 4,0 8,4" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Grid.Row="1" Margin="0,0,3,2" Click="AdjustValue_Click" Tag="WidthBox_Down">
                                        <Polygon Points="0,0 4,4 8,0" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </Grid>

                            <Grid Grid.Row="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="OneAlignmentCheck" Grid.Column="0" Content="ON" Margin="3,3,1.5,3" Click="OneAlignmentCheck_Click"/>

                                <TextBlock Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#f9f9f9" Margin=" 3,3,3,4" Padding="2"><Run Text="Одне вирівнювання для вс"/><Run Language="uk-ua" Text="іх"/></TextBlock>
                            </Grid>

                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="55" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ToggleButton x:Name="AlignmentSwitch" Grid.Column="0" Content="OFF" Margin="3,3,1.5,3" Click="AlignmentSwitch_Click"/>

                                <Border Grid.Column="1" Background="#f9f9f9" Margin="4,4.5,0,4.5" >
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Вирівнювання по:"/>
                                </Border>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Center" >
                                    <ComboBox x:Name="AlignmentComboBox" SelectedIndex="0" Margin="3,0,3,0" SelectionChanged="CropAlignmentComboBox_SelectionChanged" IsEnabled="False">
                                        <ComboBoxItem Content="Центру"/>
                                        <ComboBoxItem Content="Верх"/>
                                        <ComboBoxItem Content="Низ"/>
                                        <ComboBoxItem Content="Ліво"/>
                                        <ComboBoxItem Content="Право"/>
                                        <ComboBoxItem Content="Лівий верхній кут"/>
                                        <ComboBoxItem Content="Правий верхній кут"/>
                                        <ComboBoxItem Content="Лівий нижній кут"/>
                                        <ComboBoxItem Content="Правий нижній кут"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="25"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Row="1" Grid.Column="0" Background="#f9f9f9" Margin="4,3,0,3" >
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="X:"/>
                                </Border>

                                <Border  Grid.Column="1" Background="#f9f9f9" Margin="0,3,0,3" >
                                    <TextBox x:Name="PosXBox" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="2" Text="" TextChanged="TextBoxes_TextChanged"/>
                                </Border>

                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Button Grid.Row="0" Margin="0,2,1.5,0" Click="AdjustValue_Click" Tag="PosXBox_Up">
                                        <Polygon Points="0,4 4,0 8,4" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Grid.Row="1" Margin="0,0,1.5,2" Click="AdjustValue_Click" Tag="PosXBox_Down">
                                        <Polygon Points="0,0 4,4 8,0" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>

                                <Border Grid.Row="1" Grid.Column="3" Background="#f9f9f9" Margin="4,3,0,3" >
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Y:"/>
                                </Border>

                                <Border  Grid.Column="4" Background="#f9f9f9" Margin="0,3,0,3" >
                                    <TextBox x:Name="PosYBox" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Padding="2" Text="" TextChanged="TextBoxes_TextChanged"/>
                                </Border>

                                <Grid Grid.Column="5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Button Grid.Row="0" Margin="0,2,3,0" Click="AdjustValue_Click" Tag="PosYBox_Up">
                                        <Polygon Points="0,4 4,0 8,4" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Grid.Row="1" Margin="0,0,3,2" Click="AdjustValue_Click" Tag="PosYBox_Down">
                                        <Polygon Points="0,0 4,4 8,0" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!--НИЖНЯ ПАНЕЛЬ-->
        <!--НИЖНЯ ПАНЕЛЬ-->
        <!--НИЖНЯ ПАНЕЛЬ-->
        <!--НИЖНЯ ПАНЕЛЬ-->
        <!--НИЖНЯ ПАНЕЛЬ-->

        <Border Grid.Row="4" Background="#999999" BorderThickness="2" CornerRadius="25, 25, 0, 0" Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#545454" HorizontalAlignment="Stretch" BorderThickness="0" CornerRadius="10, 10, 0, 0" Grid.Column="1" VerticalAlignment="Top" Height="50">
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <!--верхня панель-->

                        <!--верхній ряд-->

                        <ToggleButton x:Name="WatermarkToggle" Grid.Row="0" Grid.Column="0" Background="#f9f9f9" Margin="5,10,5,10" Content="OFF" IsChecked="False" Click="WatermarkToggle_Click"/>

                        <Border Grid.Row="1" Grid.Column="1" Background="#f9f9f9" Margin="0,10,6,10" IsEnabled="{Binding ElementName=WatermarkToggle, Path=IsChecked}">
                            <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Вхід"/>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2" Background="#f9f9f9" Margin="0,10,0,10" CornerRadius="0, 0, 0, 0" IsEnabled="{Binding ElementName=WatermarkToggle, Path=IsChecked}">
                            <TextBox x:Name="M2WatermarkPath" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Text="Вхід" Padding="5" LostFocus="SelectFolder_Click"/>
                        </Border>

                        <Button x:Name="ButtonWatermarkBrowse" IsEnabled="{Binding ElementName=WatermarkToggle, Path=IsChecked}" Grid.Row="0" Grid.Column="3" Background="#f9f9f9" Margin="5,10,5,10" Padding="-3" Content="Browse..." Click="SelectFolder_Click"></Button>

                        <!--нижня панель-->
                    </Grid>
                </Border>


                <!--фото-->
                <Grid Grid.Row="1" IsEnabled="{Binding ElementName=WatermarkToggle, Path=IsChecked}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32*"/>
                        <ColumnDefinition Width="1011*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="SquareBorderN1" Grid.Column="0" Margin="4,0,0,0" Background="#999999" CornerRadius="0" HorizontalAlignment="Left" 
                            Width="{Binding RelativeSource={RelativeSource Self}, Path=ActualHeight}" Grid.ColumnSpan="2">
                        <Image x:Name="WatermarkPreviewImage" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" IsEnabled="{Binding ElementName=WatermarkToggle, Path=IsChecked}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding ElementName=SquareBorderN1, Path=ActualWidth}" />
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                </Grid>

                <Grid Grid.Row="3" IsEnabled="{Binding ElementName=WatermarkToggle, Path=IsChecked}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding ElementName=SquareBorder, Path=ActualWidth}" />
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Row="2" Grid.Column="0" Margin="3,0,-3,3" Background="#545454">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Margin="0,0,0,0" Click="WatermarkBack_Click">
                                <Polygon Points="4,0 0,4 4,8" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="1" Margin="0,0,0,0" Click="WatermarkForward_Click">
                            <Polygon Points="0,0 4,4 0,8" Fill="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Grid>

                <!--налаштування-->

                <Grid Grid.Row="1" Grid.RowSpan="3" IsEnabled="{Binding ElementName=WatermarkToggle, Path=IsChecked}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding ElementName=SquareBorderN1, Path=ActualWidth}" />
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <Border Grid.Column="1" Background="Gray" Margin="8,0,3,3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="216"/>
                                    <ColumnDefinition Width="95"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="55"/>
                                    <ColumnDefinition Width="55"/>
                                </Grid.ColumnDefinitions>

                                <ToggleButton x:Name="ApplyToAllWatermark" Grid.Column="1" Content="Для цьго поля" Margin="3,3,1.5,3" Checked="ApplyToAllWatermark_Checked" Unchecked="ApplyToAllWatermark_Unchecked"/>

                                <Border Grid.Column="0" Background="#f9f9f9" Margin="4,3,1.5,3">
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Завантажити/Зберегти налаштування"/>
                                </Border>

                                <StackPanel Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Height="22">
                                    <ComboBox     x:Name="MyComboBoxN3Watermark" Grid.Column="2" Margin="3,0,3,0" IsEditable="True" IsReadOnly="False" StaysOpenOnEdit="True" SelectionChanged="MyComboBoxN3Watermark_SelectionChanged"/>
                                </StackPanel>

                                <Button x:Name="SaveProfileWatermark" Grid.Column="3" Margin="1.5,4,3,4" Content="Save" Click="SaveProfileWatermark_Click">
                                </Button>

                                <Button x:Name="DeleteProfileWatermark" Grid.Column="4" Margin="1.5,4,3,4" Content="Del" Click="DeleteProfileWatermark_Click">
                                </Button>
                            </Grid>




                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Row="1" Grid.Column="0" Background="#f9f9f9" Margin="4,3,1.5,3">
                                    <TextBlock Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Водяний знак №"/>
                                </Border>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Height="22">
                                    <ComboBox x:Name="MyComboBoxN1" SelectedIndex="0" Margin="3,0,0,0" SelectionChanged="MyComboBoxN1_SelectionChanged"/>
                                </StackPanel>
                                
                                <Button x:Name="ButtonAddWatermark" Grid.Column="2" Content="+1" Margin="5,4,1,4" Click="ButtonAddWatermark_Click"/>
                                <Button x:Name="ButtonRemoveWatermark" Grid.Column="3" Content="-1" Margin="4,4,2,4" Click="ButtonRemoveWatermark_Click"/>
                            </Grid>

