<Window x:Class="ImageProcessing.Pages.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редагування користувача"
        Width="320" Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="LabelText" Grid.Row="0" Text="Введіть нове значення:" Margin="0,0,0,6" FontWeight="SemiBold"/>

        <PasswordBox x:Name="InputPasswordBox" Grid.Row="1" Height="32" Padding="4,0" Visibility="Collapsed"/>

        <TextBox x:Name="InputTextBox" Grid.Row="1" Height="32" Padding="4,0"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Підтвердити" Width="100" Height="30" Margin="0,0,8,0" Click="Confirm_Click"/>
            <Button Content="Скасувати" Width="80" Height="30" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
