<Window x:Class="ImageProcessing.Pages.ConfirmIdentityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Підтвердження особистості"
        Width="320" Height="230"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Введіть дані поточного акаунту:" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Text="Ім'я"/>
        <TextBox x:Name="LoginBox" Grid.Row="2" Height="32" Padding="4,0" Margin="0,0,0,0"/>

        <TextBlock Grid.Row="3" Text="Пароль" />
        <PasswordBox x:Name="PasswordBox" Grid.Row="4" Height="32" Padding="4,0"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Підтвердити" Width="100" Height="30" Margin="0,0,8,0" Click="Confirm_Click"/>
            <Button Content="Скасувати" Width="80" Height="30" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
