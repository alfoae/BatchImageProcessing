<Page x:Class="ImageProcessing.Pages.History"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ImageProcessing.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="History">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            
            <TextBox x:Name="SearchBox" Width="200" Height="30" Margin="0,0,10,0" TextChanged="FilterChanged"/>
            
            <ComboBox x:Name="StatusFilter" Width="140" Height="30" SelectionChanged="FilterChanged">
                <ComboBoxItem Content="Усі"/>
                <ComboBoxItem Content="Завершені"/>
                <ComboBoxItem Content="Скасовані"/>
            </ComboBox>
            
            <ComboBox x:Name="SortBox" Width="180" Height="30" Margin="10,0,0,0" SelectionChanged="FilterChanged">
                <ComboBoxItem Content="Спочатку нові"/>
                <ComboBoxItem Content="Спочатку старі"/>
                <ComboBoxItem Content="Більше файлів"/>
                <ComboBoxItem Content="Менше файлів"/>
            </ComboBox>
            
            <ComboBox x:Name="PageSizeBox" Width="100" Height="30" Margin="10,0,0,0" SelectionChanged="FilterChanged">
                <ComboBoxItem Content="20"/>
                <ComboBoxItem Content="50"/>
                <ComboBoxItem Content="100"/>
            </ComboBox>
            
        </StackPanel>

        <DataGrid x:Name="HistoryGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Назва" Binding="{Binding TaskName}"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding Date}"/>
                <DataGridTextColumn Header="Файлів" Binding="{Binding FileCount}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
