<Window x:Class="ImageProcessing.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обробка фотографій" Height="180" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText" Text="Обробка: 0 з 0" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <ProgressBar x:Name="MainProgressBar" Grid.Row="1" Height="25" Margin="0,5,0,15"/>

        <Button x:Name="CancelBtn" Grid.Row="2" Content="Отмена 🛑" Width="100" Height="30" HorizontalAlignment="Right" Click="CancelBtn_Click" Background="Red" Foreground="White" FontWeight="Bold"/>
    </Grid>
</Window>